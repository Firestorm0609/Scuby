In handlers.py, inside handle_menu_button(), add:

    elif action == "wallets":
        from wallet_tracker import handle_wallets
        # Redirect to the full wallets handler
        chat_id      = str(query.message.chat.id) if query.message else None
        wallets      = context.bot_data.get("tracked_wallets", {})
        chat_wallets = wallets.get(chat_id, []) if chat_id else []
        if not chat_wallets:
            await query.edit_message_text(
                "🐋 Not tracking any wallets yet\\!\\n\\nStart with:\\n`/trackwallet <address> [label]`",
                parse_mode="MarkdownV2",
                reply_markup=InlineKeyboardMarkup([[
                    InlineKeyboardButton("🏠 Main Menu", callback_data="menu|home")
                ]]),
            )
        else:
            e     = escape_md
            lines = ["🐋 *Tracked wallets:*\\n"]
            for w in chat_wallets:
                lbl = e(w.get("label") or w["address"][:12] + "...")
                lines.append(f"• {lbl}")
            rows = [[InlineKeyboardButton(
                f"❌ {(w.get('label') or w['address'][:12] + '...')[:30]}",
                callback_data=f"delwallet|{w['id']}",
            )] for w in chat_wallets]
            rows.append([InlineKeyboardButton("🏠 Main Menu", callback_data="menu|home")])
            await query.edit_message_text(
                "\\n".join(lines), parse_mode="MarkdownV2",
                reply_markup=InlineKeyboardMarkup(rows),
            )

    elif action == "patterns":
        await query.edit_message_text("Loading patterns...\\nUse /patterns for the full view\\! 🐾")

