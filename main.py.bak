STEP 10: Fix /portfolio command not registered in main.py
────────────────────────────────────────────────────────────────

In handlers.py, add this handler (it exists as an intent but not a /command):

async def handle_portfolio_command(update, context):
    if not update.message or not update.effective_user:
        return
    from portfolio import build_portfolio_snapshot, portfolio_keyboard
    user_id = update.effective_user.id
    http    = context.bot_data["http"]
    msg = await update.message.reply_text("🐾 Fetching your bag, Raggy...", parse_mode="MarkdownV2")
    try:
        text = await build_portfolio_snapshot(user_id, http, context.bot_data)
        await msg.edit_text(
            text, parse_mode="MarkdownV2",
            disable_web_page_preview=True,
            reply_markup=portfolio_keyboard(user_id),
        )
    except Exception as ex:
        await msg.edit_text("Zoinks! Couldn't load portfolio. Try again!")

Then in main(), add:
    app.add_handler(CommandHandler("portfolio",  handle_portfolio_command))
    app.add_handler(CommandHandler("addtoken",   handle_addtoken_command))   # optional
"""


# ─── Quick install script ────────────────────────────────────────────────────

INSTALL_SCRIPT = """#!/bin/bash
# install_upgrades.sh — run from project root to apply all upgrades

set -e

echo "Scooby Upgrade Script v2"
echo "========================"

# Step 1: Copy new/upgraded files
echo "Copying upgraded files..."
cp gemscore.py gemscore.py.bak 2>/dev/null || true
cp gemscore_upgraded.py gemscore.py

cp handlers_ai_addition_new.py handlers_ai_addition.py

# Step 2: Append memory additions
echo "Patching memory.py..."
echo "" >> memory.py
cat memory_additions.py >> memory.py

# Step 3: Copy wallet tracker
cp wallet_tracker.py wallet_tracker.py

echo ""
echo "Manual steps required:"
echo "  1. Add wallet_tracker imports to main.py (see main_upgraded.py)"
echo "  2. Register wallet commands in main.py (see main_upgraded.py)"
echo "  3. Add 'from telegram import InlineKeyboardButton, InlineKeyboardMarkup' to jobs.py"
echo "  4. Add wallet_scan_job to post_init() job queue"
echo ""
echo "Done! Restart Scooby: python main.py"
"""

if __name__ == "__main__":
    print(INSTALL_SCRIPT)
