"""
wallet_tracker.py — Scooby's whale wallet tracker.

Track Solana wallets and get alerted when they make significant moves.
Uses the Helius RPC (free tier) + DexScreener for price context.

Commands:
  /trackwallet <address> [label]  — start tracking a wallet
  /wallets                        — list tracked wallets
  /untrackwallet <address|label>  — stop tracking

Background job: wallet_scan_job (every 5 minutes)
  - Compares current token holdings vs last snapshot
  - Alerts when wallet adds/removes a significant position
"""

import asyncio
import copy
import json
import logging
import os
import time
from datetime import datetime, timezone
from typing import Any

import httpx
from telegram import InlineKeyboardButton, InlineKeyboardMarkup, Update
from telegram.ext import ContextTypes

from utils import escape_md, safe_float, dex_get

logger = logging.getLogger(__name__)

WALLETS_FILE          = "tracked_wallets.json"
MAX_WALLETS_PER_CHAT  = 5
WALLET_POLL_INTERVAL  = 300   # 5 minutes
MIN_VALUE_USD_ALERT   = 500   # ignore dust positions
HELIUS_RPC_URL        = os.environ.get(
    "HELIUS_RPC_URL",
    "https://api.mainnet-beta.solana.com",  # public fallback (rate-limited)
)


# ─── Persistence ──────────────────────────────────────────────────────────────

def load_wallets() -> dict:
    try:
        with open(WALLETS_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def save_wallets(w: dict) -> None:
    try:
        with open(WALLETS_FILE, "w") as f:
            json.dump(w, f)
    except Exception as ex:
        logger.warning(f"Could not save wallets: {ex}")


async def save_wallets_async(w: dict) -> None:
    await asyncio.to_thread(save_wallets, copy.deepcopy(w))


# ─── Solana RPC helpers ───────────────────────────────────────────────────────

async def _get_token_accounts(wallet_address: str, http: httpx.AsyncClient) -> list[dict]:
    """
    Fetch all SPL token accounts for a wallet using Solana JSON-RPC.
    Returns a list of {mint, amount, decimals} dicts.
    """
    payload = {
        "jsonrpc": "2.0",
        "id":      1,
        "method":  "getTokenAccountsByOwner",
        "params": [
            wallet_address,
            {"programId": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA"},
            {"encoding": "jsonParsed"},
        ],
    }
    try:
        resp = await http.post(HELIUS_RPC_URL, json=payload, timeout=12)
        resp.raise_for_status()
        data    = resp.json()
        result  = data.get("result", {}) or {}
        value   = result.get("value", []) or []
        accounts = []
        for item in value:
            info = (
                item.get("account", {})
                    .get("data", {})
                    .get("parsed", {})
                    .get("info", {})
            )
            mint_info = info.get("mint", "")
            tok_amount = info.get("tokenAmount", {})
            amount    = safe_float(tok_amount.get("amount", 0))
            decimals  = int(tok_amount.get("decimals", 0))
            if mint_info and amount > 0:
                accounts.append({
                    "mint":     mint_info,
                    "amount":   amount,
                    "decimals": decimals,
                    "ui_amount": amount / (10 ** decimals) if decimals else amount,
                })
        return accounts
    except Exception as ex:
        logger.warning(f"_get_token_accounts({wallet_address[:8]}...): {ex}")
        return []


async def _get_sol_balance(wallet_address: str, http: httpx.AsyncClient) -> float:
    """Get native SOL balance in SOL."""
    payload = {
        "jsonrpc": "2.0", "id": 1,
        "method":  "getBalance",
        "params":  [wallet_address],
    }
    try:
        resp = await http.post(HELIUS_RPC_URL, json=payload, timeout=8)
        resp.raise_for_status()
        lamports = resp.json().get("result", {}).get("value", 0) or 0
        return lamports / 1_000_000_000
    except Exception:
        return 0.0


async def _enrich_with_prices(
    accounts: list[dict],
    http: httpx.AsyncClient,
) -> list[dict]:
    """
    Add USD price data from DexScreener to each account.
    Returns accounts with: price_usd, value_usd, symbol, name added.
    """
    if not accounts:
        return accounts

    mints = [a["mint"] for a in accounts]
    batch_size = 30
    prices: dict[str, dict] = {}

    for i in range(0, len(mints), batch_size):
        batch = mints[i : i + batch_size]
        try:
            data = await dex_get(
                http,
                f"https://api.dexscreener.com/latest/dex/tokens/{','.join(batch)}",
            )
            for pair in data.get("pairs") or []:
                if pair.get("chainId") != "solana":
                    continue
                ca    = pair.get("baseToken", {}).get("address", "")
                price = safe_float(pair.get("priceUsd") or 0)
                if ca and ca not in prices and price > 0:
                    prices[ca] = {
                        "price_usd": price,
                        "symbol":    pair.get("baseToken", {}).get("symbol", "?"),
                        "name":      pair.get("baseToken", {}).get("name", "?"),
                        "h1":        safe_float((pair.get("priceChange") or {}).get("h1", 0)),
                        "h24":       safe_float((pair.get("priceChange") or {}).get("h24", 0)),
                        "dex_url":   f"https://dexscreener.com/solana/{ca}",
                    }
        except Exception as ex:
            logger.debug(f"_enrich_with_prices batch {i}: {ex}")

    enriched = []
    for acct in accounts:
        mint = acct["mint"]
        info = prices.get(mint, {})
        price = info.get("price_usd", 0)
        value = acct["ui_amount"] * price if price else 0
        enriched.append({
            **acct,
            "price_usd": price,
            "value_usd": value,
            "symbol":    info.get("symbol", mint[:8]),
            "name":      info.get("name", ""),
            "h1":        info.get("h1", 0),
            "h24":       info.get("h24", 0),
            "dex_url":   info.get("dex_url", f"https://dexscreener.com/solana/{mint}"),
        })
    return sorted(enriched, key=lambda x: x["value_usd"], reverse=True)


# ─── Snapshot diffing ─────────────────────────────────────────────────────────

def _diff_snapshots(
    prev: list[dict],
    curr: list[dict],
) -> tuple[list[dict], list[dict], list[dict]]:
    """
    Compare two wallet snapshots.
    Returns (added, removed, changed) lists of enriched account dicts.
    """
    prev_map = {a["mint"]: a for a in prev}
    curr_map = {a["mint"]: a for a in curr}

    added   = [curr_map[m] for m in curr_map if m not in prev_map]
    removed = [prev_map[m] for m in prev_map if m not in curr_map]
    changed = []

    for mint in curr_map:
        if mint not in prev_map:
            continue
        p = prev_map[mint]
        c = curr_map[mint]
        # Significant change: > 20% difference in amount
        if p["amount"] > 0:
            change_pct = abs(c["amount"] - p["amount"]) / p["amount"]
            if change_pct >= 0.20:
                changed.append({**c, "_prev_amount": p["amount"], "_change_pct": change_pct})

    return added, removed, changed


# ─── Alert message builder ────────────────────────────────────────────────────

def build_wallet_alert(
    wallet_label: str,
    wallet_address: str,
    added: list[dict],
    removed: list[dict],
    changed: list[dict],
) -> str | None:
    """Build a MarkdownV2 alert message. Returns None if nothing notable."""
    e = escape_md

    # Filter out dust
    added_sig   = [a for a in added   if a["value_usd"] >= MIN_VALUE_USD_ALERT]
    removed_sig = [r for r in removed if r["value_usd"] >= MIN_VALUE_USD_ALERT or r.get("price_usd", 0) == 0]
    changed_sig = [c for c in changed if c["value_usd"] >= MIN_VALUE_USD_ALERT]

    if not added_sig and not removed_sig and not changed_sig:
        return None

    short_addr = f"{wallet_address[:6]}\\.\\.\\."
    label_str  = e(wallet_label) if wallet_label else short_addr
    now_str    = datetime.now(timezone.utc).strftime("%H:%M UTC")
    lines      = [
        f"🐋 *Wallet Alert — {label_str}*\n"
        f"`{e(wallet_address)}`\n"
        f"_Scooby noticed activity at {e(now_str)}_\n"
    ]

    if added_sig:
        lines.append("📥 *Bought / received:*")
        for a in added_sig[:5]:
            sym   = e(a.get("symbol", "?"))
            val   = f"${a['value_usd']:,.0f}" if a["value_usd"] else "?"
            h1    = a.get("h1", 0)
            h1str = e(f"{h1:+.1f}%")
            dex   = a.get("dex_url", "")
            lines.append(
                f"  • [{sym}]({dex}) — *{e(val)}* "
                f"\\({e('{:,.2f}'.format(a.get('ui_amount', 0)))} tokens, {h1str} 1h\\)"
            )

    if removed_sig:
        lines.append("📤 *Sold / removed:*")
        for r in removed_sig[:5]:
            sym = e(r.get("symbol", "?"))
            dex = r.get("dex_url", "")
            lines.append(f"  • [{sym}]({dex})")

    if changed_sig:
        lines.append("🔄 *Position changed:*")
        for c in changed_sig[:3]:
            sym      = e(c.get("symbol", "?"))
            pct      = c.get("_change_pct", 0)
            prev_amt = c.get("_prev_amount", 0)
            curr_amt = c.get("amount", 0)
            direction = "increased" if curr_amt > prev_amt else "decreased"
            dex = c.get("dex_url", "")
            lines.append(
                f"  • [{sym}]({dex}) {e(direction)} by *{e(f'{pct:.0%}')}*"
            )

    lines.append(f"\n_⚠️ DYOR\\. Not financial advice\\._")
    return "\n".join(lines)


# ─── Command handlers ─────────────────────────────────────────────────────────

async def handle_trackwallet(update, context: ContextTypes.DEFAULT_TYPE):
    """
    /trackwallet <address> [optional label]
    """
    from telegram import Update
    if not update.message or not update.effective_chat:
        return

    args = context.args or []
    if not args:
        await update.message.reply_text(
            "🐋 *Track a Whale Wallet*\n\n"
            "Usage: `/trackwallet <solana_address> [label]`\n\n"
            "Examples:\n"
            "  `/trackwallet 9xQ...abc`\n"
            "  `/trackwallet 9xQ...abc VentureWhale`\n\n"
            f"_Max {MAX_WALLETS_PER_CHAT} wallets per chat\\. "
            "Scooby checks every 5 minutes\\._",
            parse_mode="MarkdownV2",
        )
        return

    address = args[0].strip()
    label   = " ".join(args[1:]).strip() if len(args) > 1 else ""

    # Basic Solana address validation
    if len(address) < 32 or len(address) > 44:
        await update.message.reply_text(
            "Jinkies\\! 🔍 That doesn't look like a valid Solana address\\. "
            "Addresses are 32–44 characters long\\.",
            parse_mode="MarkdownV2",
        )
        return

    chat_id = str(update.effective_chat.id)
    wallets = context.bot_data.setdefault("tracked_wallets", load_wallets())
    chat_wallets = wallets.setdefault(chat_id, [])

    if any(w["address"] == address for w in chat_wallets):
        await update.message.reply_text(
            "🐾 Scooby's already watching that wallet\\! Use /wallets to see it\\.",
            parse_mode="MarkdownV2",
        )
        return

    if len(chat_wallets) >= MAX_WALLETS_PER_CHAT:
        await update.message.reply_text(
            f"🐾 Already tracking *{MAX_WALLETS_PER_CHAT}* wallets here\\. "
            "Use /wallets to remove one first\\.",
            parse_mode="MarkdownV2",
        )
        return

    msg = await update.message.reply_text(
        "🐋 Scooby's taking a snapshot of that wallet\\.\\.\\. 🐾",
        parse_mode="MarkdownV2",
    )

    http: httpx.AsyncClient = context.bot_data["http"]
    accounts = await _get_token_accounts(address, http)
    enriched = await _enrich_with_prices(accounts, http)
    sol_bal  = await _get_sol_balance(address, http)

    wallet_entry = {
        "id":          f"{int(time.time() * 1000)}_{os.urandom(3).hex()}",
        "address":     address,
        "label":       label,
        "chat_id":     chat_id,
        "added_ts":    time.time(),
        "last_check":  time.time(),
        "snapshot":    enriched,
        "sol_balance": sol_bal,
    }
    chat_wallets.append(wallet_entry)
    context.bot_data["tracked_wallets"] = wallets
    await save_wallets_async(wallets)

    e          = escape_md
    label_str  = e(label) if label else f"`{e(address[:12])}\\.\\.\\. `"
    top_tokens = [t for t in enriched if t["value_usd"] >= MIN_VALUE_USD_ALERT][:5]

    lines = [
        f"🐋 *Wallet tracked\\!*\n\n"
        f"*{label_str}*\n"
        f"`{e(address)}`\n\n"
        f"💰 SOL balance: *{e(f'{sol_bal:.2f}')} SOL*\n"
        f"🪙 SPL tokens: *{len(enriched)}* positions\n\n"
    ]

    if top_tokens:
        lines.append("*Top holdings:*")
        for t in top_tokens:
            sym  = e(t.get("symbol", "?"))
            val  = f"${t['value_usd']:,.0f}"
            dex  = t.get("dex_url", "")
            lines.append(f"  • [{sym}]({dex}) — *{e(val)}*")

    lines.append(
        f"\n_Scooby checks this wallet every 5 minutes and alerts here if "
        f"it buys or sells anything significant\\._"
    )
    lines.append("_Use /wallets to manage tracked wallets\\._")

    try:
        await msg.edit_text(
            "\n".join(lines),
            parse_mode="MarkdownV2",
            disable_web_page_preview=True,
            reply_markup=InlineKeyboardMarkup([[
                InlineKeyboardButton("🐋 My wallets", callback_data="menu|wallets"),
                InlineKeyboardButton("🏠 Menu",       callback_data="menu|home"),
            ]]),
        )
    except Exception as ex:
        logger.warning(f"handle_trackwallet edit: {ex}")


async def handle_wallets(update, context: ContextTypes.DEFAULT_TYPE):
    """/wallets — list tracked wallets for this chat."""
    if not update.message or not update.effective_chat:
        return

    chat_id      = str(update.effective_chat.id)
    wallets      = context.bot_data.get("tracked_wallets", load_wallets())
    chat_wallets = wallets.get(chat_id, [])

    if not chat_wallets:
        await update.message.reply_text(
            "🐋 Not tracking any wallets here yet\\!\n\n"
            "Start with:\n`/trackwallet <address> [label]`\n\n"
            f"_Scooby can track up to {MAX_WALLETS_PER_CHAT} wallets per chat\\._",
            parse_mode="MarkdownV2",
        )
        return

    e     = escape_md
    lines = [f"🐋 *Tracked wallets \\({len(chat_wallets)}\\):*\n"]

    for i, w in enumerate(chat_wallets, 1):
        label    = e(w.get("label") or f"{w['address'][:8]}...")
        added_dt = datetime.fromtimestamp(w["added_ts"], tz=timezone.utc).strftime("%b %d")
        snap_cnt = len(w.get("snapshot", []))
        sol_bal  = w.get("sol_balance", 0)
        lines.append(
            f"*{i}\\.* *{label}*\n"
            f"   `{e(w['address'])}`\n"
            f"   _{snap_cnt} tokens \\| {e(f'{sol_bal:.2f}')} SOL \\| tracked since {e(added_dt)}_"
        )

    rows = []
    for w in chat_wallets:
        lbl = (w.get("label") or w["address"][:12] + "...")[:30]
        rows.append([InlineKeyboardButton(
            f"❌ Stop: {lbl}",
            callback_data=f"delwallet|{w['id']}",
        )])
    rows.append([InlineKeyboardButton("🏠 Main Menu", callback_data="menu|home")])

    await update.message.reply_text(
        "\n".join(lines),
        parse_mode="MarkdownV2",
        reply_markup=InlineKeyboardMarkup(rows),
    )


async def handle_untrackwallet(update, context: ContextTypes.DEFAULT_TYPE):
    """/untrackwallet <address|label>"""
    if not update.message or not update.effective_chat:
        return

    chat_id      = str(update.effective_chat.id)
    wallets      = context.bot_data.get("tracked_wallets", load_wallets())
    chat_wallets = wallets.get(chat_id, [])

    if not chat_wallets:
        await update.message.reply_text("🐾 No wallets tracked here\\!", parse_mode="MarkdownV2")
        return

    fragment = " ".join(context.args or []).strip().lower()
    if not fragment:
        await handle_wallets(update, context)
        return

    before = len(chat_wallets)
    wallets[chat_id] = [
        w for w in chat_wallets
        if fragment not in w["address"].lower()
        and fragment not in w.get("label", "").lower()
    ]
    removed = before - len(wallets[chat_id])
    context.bot_data["tracked_wallets"] = wallets
    await save_wallets_async(wallets)

    e = escape_md
    if removed:
        await update.message.reply_text(
            f"✅ Stopped tracking *{removed}* wallet\\(s\\) matching *{e(fragment)}* 🐾",
            parse_mode="MarkdownV2",
        )
    else:
        await update.message.reply_text(
            f"Hmm\\! 🐾 No wallet found matching *{e(fragment)}*\\.",
            parse_mode="MarkdownV2",
        )


async def handle_delwallet_button(update, context: ContextTypes.DEFAULT_TYPE):
    """Callback: delwallet|<wallet_id>"""
    query = update.callback_query
    await query.answer()

    parts = query.data.split("|", 1)
    if len(parts) != 2 or parts[0] != "delwallet":
        return

    wallet_id    = parts[1]
    chat_id      = str(query.message.chat.id) if query.message else None
    if not chat_id:
        return

    wallets = context.bot_data.setdefault("tracked_wallets", {})
    before  = wallets.get(chat_id, [])
    removed = [w for w in before if w["id"] == wallet_id]
    wallets[chat_id] = [w for w in before if w["id"] != wallet_id]
    await save_wallets_async(wallets)

    label = (removed[0].get("label") or removed[0]["address"][:12] + "...") if removed else "wallet"
    e = escape_md
    remaining = wallets.get(chat_id, [])

    try:
        if not remaining:
            await query.edit_message_text(
                f"✅ Stopped tracking *{e(label)}*\\.\n\n🐋 No wallets tracked here now\\.",
                parse_mode="MarkdownV2",
                reply_markup=InlineKeyboardMarkup([[
                    InlineKeyboardButton("🏠 Main Menu", callback_data="menu|home")
                ]]),
            )
        else:
            lines = [f"✅ Stopped tracking *{e(label)}*\\.\n\n🐋 *Still tracking:*\n"]
            for w in remaining:
                lbl = e(w.get("label") or f"{w['address'][:8]}...")
                lines.append(f"• {lbl}")
            rows = [[InlineKeyboardButton(
                f"❌ Stop: {(w.get('label') or w['address'][:12] + '...')[:30]}",
                callback_data=f"delwallet|{w['id']}",
            )] for w in remaining]
            rows.append([InlineKeyboardButton("🏠 Main Menu", callback_data="menu|home")])
            await query.edit_message_text(
                "\n".join(lines),
                parse_mode="MarkdownV2",
                reply_markup=InlineKeyboardMarkup(rows),
            )
    except Exception as ex:
        logger.warning(f"handle_delwallet_button: {ex}")


# ─── Background job ───────────────────────────────────────────────────────────

async def wallet_scan_job(context: ContextTypes.DEFAULT_TYPE) -> None:
    """
    Runs every WALLET_POLL_INTERVAL (5 min).
    For each tracked wallet:
      1. Fetch current token accounts
      2. Diff against last snapshot
      3. Alert if significant changes detected
    """
    wallets_data = context.bot_data.get("tracked_wallets", {})
    if not wallets_data:
        return

    http: httpx.AsyncClient = context.bot_data["http"]
    changed_global = False

    for chat_id_str, chat_wallets in list(wallets_data.items()):
        for wallet in chat_wallets:
            address  = wallet["address"]
            label    = wallet.get("label", "")
            prev_snap = wallet.get("snapshot", [])

            try:
                accounts = await _get_token_accounts(address, http)
                enriched = await _enrich_with_prices(accounts, http)
                sol_bal  = await _get_sol_balance(address, http)
            except Exception as ex:
                logger.warning(f"wallet_scan_job fetch {address[:8]}: {ex}")
                continue

            added, removed, changed = _diff_snapshots(prev_snap, enriched)
            alert_text = build_wallet_alert(label, address, added, removed, changed)

            if alert_text:
                keyboard = InlineKeyboardMarkup([[
                    InlineKeyboardButton(
                        f"🔍 Sniff added token",
                        callback_data=f"og|ca|{added[0]['mint']}" if added else "menu|home",
                    ),
                    InlineKeyboardButton("🏠 Menu", callback_data="menu|home"),
                ]])
                try:
                    await context.bot.send_message(
                        chat_id=int(chat_id_str),
                        text=alert_text,
                        parse_mode="MarkdownV2",
                        disable_web_page_preview=True,
                        reply_markup=keyboard,
                    )
                    logger.info(
                        f"Wallet alert sent: {label or address[:8]} "
                        f"add={len(added)} rem={len(removed)} chg={len(changed)} "
                        f"→ chat {chat_id_str}"
                    )
                except Exception as send_err:
                    logger.warning(f"wallet_scan_job send: {send_err}")

            # Update snapshot
            wallet["snapshot"]    = enriched
            wallet["sol_balance"] = sol_bal
            wallet["last_check"]  = time.time()
            changed_global        = True

    if changed_global:
        await save_wallets_async(wallets_data)
