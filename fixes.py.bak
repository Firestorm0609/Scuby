"""
patch_bare_summon.py
Run from your Scooby project root:  python patch_bare_summon.py

Fix: tagging @scooby (with no other text) on a friend's message now works.
Previously, stripping "@scooby" left clean="" and the handler returned early,
ignoring the replied message entirely.

Now: if clean is empty but there IS a replied message, Scooby treats it as
"read this and tell me what you think" automatically.
"""

import os, shutil, sys

TARGET = "handlers.py"

if not os.path.exists(TARGET):
    print(f"❌  {TARGET} not found.")
    sys.exit(1)

src = open(TARGET, encoding="utf-8").read()

OLD = '''\
    clean = re.sub(rf"@{re.escape(bot_username)}", "", text, flags=re.IGNORECASE) if bot_username else text
    clean = re.sub(r'\\bscooby\\b', "", clean, flags=re.IGNORECASE).strip()
    if not clean:
        return'''

NEW = '''\
    clean = re.sub(rf"@{re.escape(bot_username)}", "", text, flags=re.IGNORECASE) if bot_username else text
    clean = re.sub(r'\\bscooby\\b', "", clean, flags=re.IGNORECASE).strip()

    # If the user only said "@scooby" with no other text, check whether they
    # replied to someone's message. If yes, carry on — the replied content is
    # the subject. If there's truly nothing to work with, exit.
    if not clean:
        if not (update.message.reply_to_message and
                (update.message.reply_to_message.text or
                 update.message.reply_to_message.caption)):
            return
        # clean stays empty here; ai_input will be built from replied_text below'''

if OLD not in src:
    print("⚠️  Pattern not found — check handlers.py manually around the `if not clean` block.")
    sys.exit(1)

bak = TARGET + ".bak_summon"
shutil.copy2(TARGET, bak)
print(f"📦  Backed up → {bak}")

src = src.replace(OLD, NEW, 1)
open(TARGET, "w", encoding="utf-8").write(src)

print("✅  handlers.py patched.")
print()
print("Now works:")
print("  @scooby  (as a reply, no other text)  → Scooby reads the message and responds")
print("  @scooby thoughts?                      → same")
print("  @scooby is this a rug?                 → same, with your question added")
print()
print("Restart: python main.py")
