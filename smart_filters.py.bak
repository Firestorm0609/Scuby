"""
smart_filters.py — Natural-language driven launch filters for Scooby.

A "smart filter" is a user-defined rule set in plain English via /smartwatch:
  e.g. "pairs launched with mcap between 10k and 20k"
       "new tokens up more than 50% in the last hour with liquidity over 5k"

AI parses the description into a structured filter, which is then evaluated
against every fresh Solana pair on each SMART_FILTER_POLL_INTERVAL tick.
"""

import asyncio
import copy
import json
import logging
import os
import time
from datetime import datetime, timezone

import httpx
from telegram import InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import ContextTypes

from utils import (
    escape_md,
    safe_float,
    dex_get,
    WATCH_MIN_LIQUIDITY,
)

logger = logging.getLogger(__name__)

SMART_FILTERS_FILE       = "smart_filters.json"
SMART_FILTER_POLL_INTERVAL = 120          # 2 minutes
MAX_SMART_FILTERS_PER_CHAT = 10
SMART_FILTER_SEEN_CAP    = 500
SMART_FILTER_AGE_DEFAULT = 60            # minutes


# ─── Persistence ──────────────────────────────────────────────────────────────

def load_smart_filters() -> dict:
    try:
        with open(SMART_FILTERS_FILE, "r") as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def save_smart_filters(sf: dict) -> None:
    try:
        with open(SMART_FILTERS_FILE, "w") as f:
            json.dump(sf, f)
    except Exception as e:
        logger.warning(f"Could not save smart_filters: {e}")


async def save_smart_filters_async(sf: dict) -> None:
    await asyncio.to_thread(save_smart_filters, copy.deepcopy(sf))


# ─── Filter evaluation ────────────────────────────────────────────────────────

def pair_matches_filter(pair: dict, flt: dict, now_ms: float) -> bool:
    """
    Return True if `pair` satisfies all non-null fields in `flt`.
    """
    ca  = pair.get("baseToken", {}).get("address", "")
    if not ca:
        return False

    # Market cap
    mcap = safe_float(pair.get("marketCap") or pair.get("fdv") or 0)
    if flt.get("mcap_min") is not None and mcap < flt["mcap_min"]:
        return False
    if flt.get("mcap_max") is not None and mcap > flt["mcap_max"]:
        return False

    # Liquidity
    liq = safe_float((pair.get("liquidity") or {}).get("usd", 0))
    if liq < WATCH_MIN_LIQUIDITY:
        return False
    if flt.get("liq_min") is not None and liq < flt["liq_min"]:
        return False
    if flt.get("liq_max") is not None and liq > flt["liq_max"]:
        return False

    # Age
    created_ts = pair.get("pairCreatedAt") or 0
    age_limit  = flt.get("age_max_minutes") or SMART_FILTER_AGE_DEFAULT
    if created_ts:
        age_minutes = (now_ms - created_ts) / 60_000
        if age_minutes > age_limit:
            return False

    # % price change (1h)
    pct1h = safe_float((pair.get("priceChange") or {}).get("h1", 0))
    if flt.get("pct_change_min") is not None and pct1h < flt["pct_change_min"]:
        return False
    if flt.get("pct_change_max") is not None and pct1h > flt["pct_change_max"]:
        return False

    # 1h volume
    vol1h = safe_float((pair.get("volume") or {}).get("h1", 0))
    if flt.get("vol_min_1h") is not None and vol1h < flt["vol_min_1h"]:
        return False

    return True


# ─── Alert message builder ────────────────────────────────────────────────────

def fmt_mcap_sf(v: float) -> str:
    if v >= 1_000_000: return f"${v/1_000_000:.2f}M"
    if v >= 1_000:     return f"${v/1_000:.1f}K"
    return f"${v:.0f}"


def build_smart_filter_alert(pair: dict, flt: dict) -> tuple[str, InlineKeyboardMarkup]:
    e       = escape_md
    ca      = pair.get("baseToken", {}).get("address", "?")
    symbol  = pair.get("baseToken", {}).get("symbol", "?")
    name    = pair.get("baseToken", {}).get("name",   "?")
    price   = pair.get("priceUsd") or "?"
    mcap    = safe_float(pair.get("marketCap") or pair.get("fdv") or 0)
    liq     = safe_float((pair.get("liquidity") or {}).get("usd", 0))
    vol1h   = safe_float((pair.get("volume")    or {}).get("h1",  0))
    h1      = safe_float((pair.get("priceChange") or {}).get("h1",  0))
    h24     = safe_float((pair.get("priceChange") or {}).get("h24", 0))
    dex_url = f"https://dexscreener.com/solana/{ca}"
    x_url   = f"https://x.com/search?q={ca}"

    created_ts = pair.get("pairCreatedAt")
    if created_ts:
        age_min = int((time.time() * 1000 - created_ts) / 60_000)
        launched = datetime.fromtimestamp(created_ts / 1000, tz=timezone.utc).strftime("%H:%M UTC")
        age_line = f"🕐 Launched {e(str(age_min))}m ago \\({e(launched)}\\)\n"
    else:
        age_line = ""

    label = e(flt.get("label", "Smart Filter"))

    text = (
        f"🎯 *Smart Filter Match\\!*\n"
        f"_Filter: {label}_\n\n"
        f"🏷 *{e(symbol)}* — {e(name)}\n"
        f"`{e(ca)}`\n\n"
        f"{age_line}"
        f"💰 Price:  ${e(str(price))}\n"
        f"💎 MCap:   {e(fmt_mcap_sf(mcap))}\n"
        f"💧 Liq:    ${e(f'{liq:,.0f}')}\n"
        f"📊 Vol 1h: ${e(f'{vol1h:,.0f}')}\n"
        f"📈 1h: {e(f'{h1:+.1f}')}%  \\|  24h: {e(f'{h24:+.1f}')}%\n\n"
        f"[DexScreener]({dex_url}) \\| [X Search]({x_url})\n\n"
        f"_⚠️ DYOR, Raggy\\. Not financial advice\\._"
    )

    keyboard = InlineKeyboardMarkup([[
        InlineKeyboardButton("🔍 Sniff OG",  callback_data=f"og|ca|{ca}"),
        InlineKeyboardButton("🔄 Refresh",   callback_data=f"refreshpair|{ca}"),
    ]])

    return text, keyboard


# ─── Background scan job ───────────────────────────────────────────────────────

async def _fetch_fresh_pairs(http: httpx.AsyncClient) -> list[dict]:
    """
    Pull recently active Solana pairs from DexScreener using a handful of
    broad queries + the token-profiles endpoint.
    Returns deduplicated list of Solana pairs.
    """
    SEARCH_TERMS = ["sol", "solana", "pump", "meme", "cat", "dog", "pepe",
                    "moon", "gem", "inu", "ai", "based", "new"]

    async def _safe(q: str) -> list[dict]:
        try:
            data = await dex_get(
                http,
                "https://api.dexscreener.com/latest/dex/search",
                params={"q": q},
            )
            return [p for p in (data.get("pairs") or []) if p.get("chainId") == "solana"]
        except Exception as ex:
            logger.debug(f"_fetch_fresh_pairs: query {q!r} failed: {ex}")
            return []

    # Also hit token-profiles
    async def _profiles() -> list[dict]:
        try:
            resp = await http.get(
                "https://api.dexscreener.com/token-profiles/latest/v1", timeout=10
            )
            resp.raise_for_status()
            items = resp.json() if isinstance(resp.json(), list) else []
            cas = [i.get("tokenAddress") or i.get("address") for i in items if i.get("chainId") == "solana"]
            cas = [c for c in cas if c][:60]
            if not cas:
                return []
            batch = ",".join(cas[:30])
            data  = await dex_get(http, f"https://api.dexscreener.com/latest/dex/tokens/{batch}")
            return [p for p in (data.get("pairs") or []) if p.get("chainId") == "solana"]
        except Exception as ex:
            logger.debug(f"_profiles: {ex}")
            return []

    results = await asyncio.gather(
        _profiles(),
        *[_safe(q) for q in SEARCH_TERMS],
    )

    seen: set[str] = set()
    out: list[dict] = []
    for chunk in results:
        for p in chunk:
            ca = p.get("baseToken", {}).get("address", "")
            if ca and ca not in seen:
                seen.add(ca)
                out.append(p)
    return out


async def smart_filter_scan_job(context: ContextTypes.DEFAULT_TYPE) -> None:
    """
    Runs every SMART_FILTER_POLL_INTERVAL seconds.
    Scans fresh pairs and fires alerts for each smart filter that matches.
    """
    smart_filters: dict = context.bot_data.get("smart_filters", {})
    if not smart_filters:
        return

    http: httpx.AsyncClient = context.bot_data["http"]
    now_ms  = time.time() * 1000
    changed = False

    try:
        pairs = await _fetch_fresh_pairs(http)
    except Exception as ex:
        logger.warning(f"smart_filter_scan_job: pair fetch failed: {ex}")
        return

    if not pairs:
        return

    for chat_id_str, chat_filters in list(smart_filters.items()):
        for flt in chat_filters:
            seen_set: set = set(flt.setdefault("seen_cas", []))
            new_matches: list[dict] = []

            for pair in pairs:
                ca = pair.get("baseToken", {}).get("address", "")
                if not ca or ca in seen_set:
                    continue
                if pair_matches_filter(pair, flt, now_ms):
                    new_matches.append(pair)

            # Cap alerts per scan to avoid flooding
            for pair in new_matches[:5]:
                ca = pair.get("baseToken", {}).get("address", "")
                text, keyboard = build_smart_filter_alert(pair, flt)
                try:
                    await context.bot.send_message(
                        chat_id=int(chat_id_str),
                        text=text,
                        parse_mode="MarkdownV2",
                        disable_web_page_preview=True,
                        reply_markup=keyboard,
                    )
                    flt["seen_cas"].append(ca)
                    seen_set.add(ca)
                    changed = True
                    try:
                        from memory import record_filter_hit, save_filter_scores_async
                        sniff_price   = safe_float(pair.get("priceUsd") or 0)
                        filter_scores = context.bot_data.setdefault("filter_scores", {})
                        sym           = pair.get("baseToken", {}).get("symbol", "?")
                        record_filter_hit(filter_scores, flt["id"], flt.get("label","?"), ca, sym, sniff_price)
                        await save_filter_scores_async(filter_scores)
                    except Exception as fs_err:
                        logger.debug(f"filter score record: {fs_err}")
                    logger.info(
                        f"SmartFilter alert → chat {chat_id_str}: "
                        f"{pair.get('baseToken',{}).get('symbol','?')} "
                        f"matched '{flt.get('label','?')}'"
                    )
                except Exception as send_err:
                    logger.warning(f"smart_filter_scan_job: send failed: {send_err}")

            # Prune seen_cas
            if len(flt["seen_cas"]) > SMART_FILTER_SEEN_CAP:
                flt["seen_cas"] = flt["seen_cas"][-SMART_FILTER_SEEN_CAP:]

    if changed:
        await save_smart_filters_async(smart_filters)
