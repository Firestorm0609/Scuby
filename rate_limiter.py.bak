"""
rate_limiter.py — shared DexScreener rate limiter for Scooby.

DexScreener free tier: ~300 requests/minute, but bursting 50 at once
triggers 429s. This module enforces:
  - Max 8 concurrent requests at any time (semaphore)
  - Min 0.15s between requests (token bucket)
  - Exponential backoff on 429: 2s, 4s, 8s (max 3 retries)
  - Shared result cache: 45s TTL so multiple jobs don't re-fetch same data

Usage:
  from rate_limiter import dex_get_safe, clear_cache

  # Drop-in replacement for utils.dex_get in all jobs
  data = await dex_get_safe(http, url, params={"q": "bonk"})
"""

import asyncio
import logging
import time
from typing import Optional

import httpx

logger = logging.getLogger(__name__)

# ─── Config ───────────────────────────────────────────────────────────────────

MAX_CONCURRENT    = 8      # max simultaneous DexScreener requests
MIN_DELAY_SECS    = 0.15   # min seconds between request starts
CACHE_TTL_SECS    = 45     # seconds to cache identical URL+params results
MAX_RETRIES       = 3      # retries on 429
BACKOFF_BASE_SECS = 2.0    # first retry after 2s, then 4s, then 8s

# ─── State ────────────────────────────────────────────────────────────────────

_semaphore:    Optional[asyncio.Semaphore] = None
_last_request: float = 0.0
_throttle_lock = asyncio.Lock()

# Cache: key → (data, expires_at)
_cache: dict[str, tuple[dict, float]] = {}
_cache_lock = asyncio.Lock()


def _get_semaphore() -> asyncio.Semaphore:
    global _semaphore
    if _semaphore is None:
        _semaphore = asyncio.Semaphore(MAX_CONCURRENT)
    return _semaphore


def _cache_key(url: str, params: Optional[dict]) -> str:
    if not params:
        return url
    param_str = "&".join(f"{k}={v}" for k, v in sorted(params.items()))
    return f"{url}?{param_str}"


async def _get_cached(key: str) -> Optional[dict]:
    async with _cache_lock:
        entry = _cache.get(key)
        if entry and time.monotonic() < entry[1]:
            return entry[0]
        if entry:
            del _cache[key]
    return None


async def _set_cached(key: str, data: dict) -> None:
    async with _cache_lock:
        _cache[key] = (data, time.monotonic() + CACHE_TTL_SECS)
        # Prune if too large
        if len(_cache) > 500:
            now = time.monotonic()
            expired = [k for k, (_, exp) in _cache.items() if exp < now]
            for k in expired:
                del _cache[k]


async def clear_cache() -> None:
    """Clear the entire result cache. Call this if you need fresh data."""
    async with _cache_lock:
        _cache.clear()


# ─── Core rate-limited fetch ──────────────────────────────────────────────────

async def dex_get_safe(
    http: httpx.AsyncClient,
    url: str,
    params: Optional[dict] = None,
) -> dict:
    """
    Rate-limited, cached, retrying replacement for utils.dex_get.

    - Checks cache first (45s TTL)
    - Enforces max 8 concurrent requests via semaphore
    - Enforces min 150ms between request starts
    - Retries up to 3 times on 429 with exponential backoff
    - Returns {} on persistent failure (never raises)
    """
    key = _cache_key(url, params)

    # ── Cache hit ─────────────────────────────────────────────────────────────
    cached = await _get_cached(key)
    if cached is not None:
        return cached

    sem = _get_semaphore()

    async with sem:
        # ── Re-check cache (another coroutine may have fetched while we waited)
        cached = await _get_cached(key)
        if cached is not None:
            return cached

        # ── Throttle: enforce min delay between request starts ────────────────
        async with _throttle_lock:
            global _last_request
            now   = time.monotonic()
            gap   = now - _last_request
            if gap < MIN_DELAY_SECS:
                await asyncio.sleep(MIN_DELAY_SECS - gap)
            _last_request = time.monotonic()

        # ── Fetch with retry on 429 ───────────────────────────────────────────
        last_err = None
        for attempt in range(MAX_RETRIES + 1):
            try:
                resp = await http.get(url, params=params)

                if resp.status_code == 429:
                    wait = BACKOFF_BASE_SECS * (2 ** attempt)
                    logger.warning(
                        f"DexScreener 429 on {url} "
                        f"(attempt {attempt+1}/{MAX_RETRIES+1}) — "
                        f"backing off {wait:.1f}s"
                    )
                    if attempt < MAX_RETRIES:
                        await asyncio.sleep(wait)
                        continue
                    else:
                        logger.error(f"DexScreener 429 — all retries exhausted for {url}")
                        return {}

                resp.raise_for_status()
                data = resp.json()
                result = data if isinstance(data, dict) else {}

                await _set_cached(key, result)
                return result

            except httpx.HTTPStatusError as e:
                if e.response.status_code == 429:
                    wait = BACKOFF_BASE_SECS * (2 ** attempt)
                    if attempt < MAX_RETRIES:
                        await asyncio.sleep(wait)
                        continue
                last_err = e
                break
            except Exception as e:
                last_err = e
                if attempt < MAX_RETRIES:
                    await asyncio.sleep(BACKOFF_BASE_SECS)
                    continue
                break

        logger.warning(f"dex_get_safe failed for {url}: {last_err}")
        return {}


# ─── Chunked parallel helper ──────────────────────────────────────────────────

async def dex_search_many(
    http: httpx.AsyncClient,
    queries: list[str],
    chain: str = "solana",
    chunk_size: int = 6,
) -> list[dict]:
    """
    Run many DexScreener search queries with controlled concurrency.
    Instead of asyncio.gather(*all_50_queries), fires them in chunks of
    chunk_size with a small delay between chunks.

    Returns a deduplicated flat list of pair dicts for the given chain.
    """
    seen_cas: set[str] = set()
    all_pairs: list[dict] = []

    for i in range(0, len(queries), chunk_size):
        chunk = queries[i:i + chunk_size]

        async def _one(q: str) -> list[dict]:
            data = await dex_get_safe(
                http,
                "https://api.dexscreener.com/latest/dex/search",
                params={"q": q},
            )
            return [p for p in (data.get("pairs") or []) if p.get("chainId") == chain]

        results = await asyncio.gather(*[_one(q) for q in chunk], return_exceptions=True)

        for result in results:
            if isinstance(result, Exception):
                continue
            for pair in result:
                ca = pair.get("baseToken", {}).get("address", "")
                if ca and ca not in seen_cas:
                    seen_cas.add(ca)
                    all_pairs.append(pair)

        # Brief pause between chunks to avoid bursting
        if i + chunk_size < len(queries):
            await asyncio.sleep(0.3)

    return all_pairs
